{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "node",
  "separate-pull-requests": true,
  "packages": {
    ".": {
      "release-type": "node",
      "package-name": "datacenter-site",
      "tag-name": "datacenter-site-v${version}",
      "pull-request-title-pattern": "release: site v${version}",
      "changelog-path": "CHANGELOG.md",
      "bump-minor-pre-major": true,
      "bump-patch-for-minor-pre-major": true,
      "draft": false,
      "prerelease": false
    },
    "server": {
      "release-type": "node",
      "package-name": "datacenter-game-server",
      "tag-name": "datacenter-game-server-v${version}",
      "pull-request-title-pattern": "release: server v${version}",
      "changelog-path": "CHANGELOG.md",
      "bump-minor-pre-major": true,
      "bump-patch-for-minor-pre-major": true
    }
  }
}
